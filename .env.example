# ============================================
# MePesewa environment variables
# Copy this file to .env and fill in real values
# Never commit .env to git (it's already in .gitignore)
# ============================================

# ---- Firebase (Auth + Firestore) ----
# Get these from: Firebase Console > Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ---- Anthropic (AI Coach) ----
# This key is used SERVER-SIDE ONLY by netlify/functions/chat.js
# It is NOT prefixed with VITE_ so it never gets bundled into the browser.
# Get it from: console.anthropic.com > API Keys
ANTHROPIC_API_KEY=
